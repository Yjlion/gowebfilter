<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SYSTEM_EXEMPTED" />
    <!-- Proxy-only mode runs the same service WITHOUT establish(), so the
         systemExempted type (which requires an active VPN) is not
         permitted; specialUse is the documented escape hatch for it. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Needed to list installed apps for the per-app filtering picker. -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission"
        xmlns:tools="http://schemas.android.com/tools" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.WebFilter">

        <!-- Managed-configuration (MDM/EMM) schema; see ManagedConfig.kt. -->
        <meta-data
            android:name="android.content.APP_RESTRICTIONS"
            android:resource="@xml/app_restrictions" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".AppPickerActivity"
            android:exported="false"
            android:label="@string/title_app_picker" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="@string/title_settings" />

        <activity
            android:name=".ScheduleActivity"
            android:exported="false"
            android:label="@string/title_schedule" />

        <activity
            android:name=".PoliciesActivity"
            android:exported="false"
            android:label="@string/title_policies" />

        <activity
            android:name=".CategoriesActivity"
            android:exported="false"
            android:label="@string/title_categories" />

        <activity
            android:name=".LogsActivity"
            android:exported="false"
            android:label="@string/title_logs" />

        <activity
            android:name=".AnalyticsActivity"
            android:exported="false"
            android:label="@string/title_analytics" />

        <activity
            android:name=".CaInstallActivity"
            android:exported="false"
            android:label="@string/title_ca_install" />

        <!-- The VpnService that owns the TUN and hands its fd to the Go
             engine. BIND_VPN_SERVICE is enforced by the system so only the
             OS can bind it. -->
        <service
            android:name=".WebFilterVpnService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="systemExempted|specialUse">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Proxy-only filtering mode: keeps the local HTTP filtering proxy and its management server running without a VPN." />
        </service>

        <!-- FileProvider for sharing the exported CA certificate. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
